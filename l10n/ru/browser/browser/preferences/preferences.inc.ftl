librewolf-webgl-prompt-checkbox2 =
    .label = Скрыть всплывающее окно WebGL для отдельных сайтов
    .description = Эта настройка скрывает всплывающее окно, которое появляется, когда сайт пытается создать контекст WebGL. Вы по-прежнему можете вручную вызвать это окно, нажав на значок в строке поиска.
librewolf-rfp-checkbox2 =
    .label = Включить защиту от отслеживания по цифровым отпечаткам
    .description = Включает все доступные меры по защите от отслеживания по цифровым отпечаткам, но может привести к некорректной работе некоторых веб-сайтов.
librewolf-letterboxing-checkbox2 =
    .label = Включить режим "letterboxing"
    .description = Режим "letterboxing" добавляет поля вокруг окон, чтобы обеспечить ограниченный набор округленных разрешений.
