    .description = Halten Sie Ihre Erweiterungen ohne manuellen Eingriff auf dem neuesten Stand. Eine gute Wahl für Ihre Sicherheit.
librewolf-autocopy-checkbox2 =
    .label = Einfügen per Mittelklick aktivieren
    .description = Markieren Sie einen Text, um ihn zu kopieren und fügen Sie ihn dann mit einem Mittelklick ein.
librewolf-sync-checkbox2 =
    .label = Firefox Sync aktivieren
    .description = Synchronisieren Sie Ihre Daten mit anderen Browsern. Erfordert einen Neustart.
librewolf-styling-checkbox2 =
    .label = Anpassung von userChrome.css zulassen
    .description = Aktivieren Sie diese Option, wenn Sie die Benutzeroberfläche mit einem manuell geladenen Design anpassen möchten.
