librewolf-webgl-checkbox2 =
    .label = WebGL immer zulassen
    .description = Dadurch wird WebGL immer zugelassen, ohne dass eine Berechtigung erforderlich ist.
librewolf-webgl-prompt-checkbox2 =
    .label = WebGL-Pop-up pro Website verbergen
    .description = Dadurch wird das Pop-up-Fenster ausgeblendet, das erscheint, wenn eine Website versucht, einen WebGL-Kontext zu erstellen. Sie können das Fenster weiterhin manuell aufrufen, indem Sie auf das Symbol in der Suchleiste klicken.
librewolf-rfp-checkbox2 =
    .label = Fingerprinting-Schutz aktivieren
    .description = Aktiviert alle verfügbaren Schutzmaßnahmen gegen Fingerprinting. Dies kann jedoch dazu führen, dass einige Websites nicht korrekt funktionieren.
librewolf-letterboxing-checkbox2 =
    .label = Letterboxing aktivieren
    .description = Beim Letterboxing werden um die Fenster herum Ränder eingefügt, um eine begrenzte Anzahl abgerundeter Auflösungen zurückzugeben.
