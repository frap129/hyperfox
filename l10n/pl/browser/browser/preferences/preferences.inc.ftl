librewolf-security-heading = Bezpieczeństwo
librewolf-goog-safe-download-description = Zezwól funkcji Safe Browsing na skanowanie pobrań w celu identyfikacji podejrzanych plików.
librewolf-goog-safe-description = Jeśli obawiasz się złośliwego oprogramowania lub phishingu, rozważ włączenie tej opcji.
content-blocking-section-top-level-description = LibreWolf wspiera — i domyślnie włącza — ulepszoną ochronę przed śledzeniem w trybie restrykcyjnym. Jest to jedno z najważniejszych ustawień w przeglądarce, ponieważ dostarcza rozdzielanie stanu, listy restrykcyjnego blokowania i inne przydatne funkcje prywatności. Nie zalecamy zmiany trybu na inny.
librewolf-goog-safe-download-warning1 = Wszystkie sprawdzenia odbywają się lokalnie.
librewolf-goog-safe-warning1 = Wyłączone ze względu na obawy o cenzurę ale rekomendowane dla mniej zaawansowanych użytkowników. Wszystkie sprawdzenia odbywają się lokalnie.
librewolf-styling-checkbox =
    .label = Zezwól na modyfikacje userChrome.css
librewolf-rfp-description = ResistFingerprinting jest jednym z najlepszych narzędzi zapobiegających identyfikacji.
librewolf-autocopy-checkbox =
    .label = Włącz wklejanie środkowym przyciskiem myszy
librewolf-extension-update-description = Aktualizuj rozszerzenia automatycznie. Jest to dobry wybór dla zapewnienia bezpieczeństwa.
librewolf-extension-update-warning1 = Jeśli nie sprawdzasz kodu źródłowego swoich rozszerzeń przed każdą aktualizacją powinieneś włączyć tę opcję.
librewolf-ipv6-description = Zezwól { -brand-short-name } na połączenia z użyciem IPv6.
librewolf-ipv6-warning1 = Zamiast blokady użycia IPv6 w przeglądarce zalecamy włączenie rozszerzenia prywatności IPv6 w systemie operacyjnym.
librewolf-webgl-description = Włącza WebGL z pytaniem o uprawnienia per witryna.
librewolf-webgl-warning1 = Gdy witryna spróbuje utworzyć kontekst WebGL, zostaniesz najpierw zapytany o udzielenie uprawnienia.
librewolf-rfp-warning1 = Jeśli musisz je wyłączyć, rozważ użycie rozszerzenia takiego jak Canvas Blocker.
librewolf-letterboxing-checkbox =
    .label = Włącz letterboxing
category-librewolf =
    .tooltiptext = Zmiany w about:config pogrupowane logicznie i łatwo dostępne
librewolf-warning-description = Dobraliśmy domyślne ustawienia z myślą o prywatności i bezpieczeństwie. Podczas ich modyfikacji czytaj opisy aby zrozumieć konsekwencje wprowadzonych zmian.
librewolf-broken-heading = Cyfrowy odcisk palca przeglądarki
librewolf-styling-warning1 = Upewnij się, że ufasz dostawcy motywu.
librewolf-xorigin-ref-description = Wyślij informacje o źródle żądania (referrer) tylko w obrębie tego samego serwera (same-origin).
librewolf-xorigin-ref-warning1 = Może spowodować błąd. Nawet jeśli żądanie zostanie wysłane, adres źródła żądania (referrer) zostanie obcięty.
librewolf-goog-safe-checkbox =
    .label = Włącz Google Safe Browsing
librewolf-sync-description = Synchronizuj dane z innymi przeglądarkami. Wymaga restartu.
librewolf-sync-warning1 = Firefox Sync szyfruje dane lokalnie przed przesłaniem do serwera.
librewolf-ocsp-checkbox =
    .label = Wymuś zrywanie połączeń w związku z OCSP
librewolf-xorigin-ref-checkbox =
    .label = Ogranicz przekazywanie źródeł żądania pomiędzy serwerami (cross-origin referrers)
librewolf-autocopy-description = Zaznacz tekst do skopiowania, następnie wklej korzystając ze środkowego przycisku myszy.
librewolf-styling-description = Włącz jeśli chcesz zmodyfikować interfejs użytkownika motywem wgranym samodzielnie.
librewolf-letterboxing-description = Letterboxing dodaje marginesy dookoła okna wyświetlania w celu redukcji liczby zwracanych przybliżonych rozdzielczości.
librewolf-ocsp-description = Zapobiegaj połączeniu do witryny jeśli sprawdzenia OCSP nie mogą zostać wykonane.
librewolf-ocsp-warning1 = Ta opcja zwiększa bezpieczeństwo ale spowoduje błąd połączenia kiedy serwer OCSP jest niedostępny.
permissions-webgl2 =
    .label = WebGL
librewolf-webgl-prompt-checkbox =
    .label = Ukryj okno WebGL wyskakujące per witryna
librewolf-webgl-prompt-description = Ukrywa wyskakujące okienko, które pojawia się, gdy witryna próbuje utworzyć kontekst WebGL. Możesz nadal ręcznie wywołać pytanie klikając ikonę w pasku wyszukiwania.
librewolf-general-heading2 =
    .label = Zachowanie przeglądarki
librewolf-extension-update-checkbox2 =
    .label = Aktualizuj rozszerzenia automatycznie
    .description = Utrzymuj rozszerzenia w bieżących wersjach bez ręcznej interwencji. Dobry wybór dla Twojego bezpieczeństwa.
librewolf-sync-checkbox2 =
    .label = Włącz Firefox Sync
    .description = Synchronizuj Twoje dane z innymi przeglądarkami. Wymaga ponownego uruchomienia.
librewolf-autocopy-checkbox2 =
    .label = Włącz wklejanie środkowym przyciskiem myszy
    .description = Zaznacz tekst aby go skopiować, następnie wklej klikając środkowym przyciskiem myszy.
librewolf-styling-checkbox2 =
    .label = Zezwól na dostosowywanie userChrome.css
    .description = Włącz jeśli chcesz dostosować interfejs użytkownika motywem wgranym samodzielnie.
