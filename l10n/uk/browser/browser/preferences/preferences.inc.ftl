    .description = Регулярно оновлювати розширення без самостійного втручання. Гарний вибір для вашої безпеки.
librewolf-sync-checkbox2 =
    .label = Увімкнути синхронізацію з Firefox
    .description = Синхронізуйте свої дані з іншими браузерами. Потрібне перезавантаження.
librewolf-autocopy-checkbox2 =
    .label = Вставляти текст колесом миші
    .description = Виділіть текст, щоб скопіювати, потім вставте його натисканням на колесо миші.
librewolf-styling-checkbox2 =
    .label = Дозволити налаштування userChrome.css
    .description = Увімкніть, якщо хочете налаштувати інтерфейс самостійно завантаженою темою.
librewolf-network-heading2 =
    .label = Мережа
librewolf-ipv6-checkbox2 =
    .label = Увімкнути IPv6
    .description = Дозволити { -brand-short-name } під'єднуватися через IPv6.
librewolf-privacy-heading2 =
    .label = Приватність
librewolf-xorigin-ref-checkbox2 =
    .label = Обмежити перехресні referrer-заголовки
    .description = Надсилати реферери лише у випадку однакових доменів.
librewolf-broken-heading2 =
    .label = Цифрові відбитки
librewolf-webgl-checkbox2 =
    .label = Завжди дозволяти WebGL
    .description = Завжди дозволятиме WebGL без необхідності питати дозволу.
librewolf-webgl-prompt-checkbox2 =
    .label = Ховати спливні вікна WebGL на сайтах
    .description = Ховає спливне вікно, яке з'являється, коли сайт намагається створити контекст WebGL. Ви можете відкрити вікно вручну, натиснувши на іконку в пошуковому рядку.
librewolf-rfp-checkbox2 =
    .label = Чинити опір цифровим відбиткам
    .description = Вмикає всі можливі засоби проти цифрових відбитків, але може створити проблеми з деякими сайтами.
librewolf-letterboxing-checkbox2 =
    .label = Режим поштової скриньки
    .description = Цей режим встановлює поля навколо вікон браузера, щоб сайти не відстежували вас на основі розмірів вікна.
librewolf-security-heading2 =
    .label = Безпека
librewolf-rfp-warning =
    .message = Ця функція вимкнена, бо працює опір цифровим відбиткам. Це означає, що LibreWolf примусово відтворюватиме вміст у світлій темі.
permissions-webgl2 =
    .label = WebGL
