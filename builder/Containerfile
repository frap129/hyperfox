FROM debian:trixie-slim as base

ARG LLVM_VERSION=21

# Enable deb-src so build-dep works
RUN sed -i 's/^Types: deb$/Types: deb deb-src/' /etc/apt/sources.list.d/debian.sources

# Base packages
RUN apt update -y && apt upgrade -y
RUN apt install -y \
  xwayland-run \
  dbus \
  mold \
  build-essential \
  python3 \
  python3-dev \
  python3-pip \
  python3-venv \
  wget \
  curl \
  unzip \
  zip \
  git \
  sudo \
  gpg \
  ca-certificates \
  pkg-config \
  firefox-esr

# Firefox system build dependencies (gtk3, x11, pango, etc.)
RUN apt build-dep -y firefox-esr

# Toolchains previously provided by mach bootstrap / --enable-bootstrap
RUN curl -fsSL https://apt.llvm.org/llvm-snapshot.gpg.key -o /etc/apt/trusted.gpg.d/apt.llvm.org.asc \
  && echo "deb http://apt.llvm.org/trixie/ llvm-toolchain-trixie-${LLVM_VERSION} main" > /etc/apt/sources.list.d/llvm.list \
  && apt update -y
RUN apt install -y \
  clang-${LLVM_VERSION} \
  lld-${LLVM_VERSION} \
  llvm-${LLVM_VERSION} \
  libclang-${LLVM_VERSION}-dev \
  libclang-rt-${LLVM_VERSION}-dev-wasm32 \
  libc++-${LLVM_VERSION}-dev-wasm32 \
  libc++abi-${LLVM_VERSION}-dev-wasm32 \
  nodejs \
  nasm \
  sccache \
  wasi-libc

# Rust (latest stable) + cbindgen, shared install
ENV RUSTUP_HOME=/opt/rust CARGO_HOME=/opt/cargo
RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain stable \
  && /opt/cargo/bin/cargo install cbindgen \
  && chmod -R a+rwX /opt/cargo /opt/rust

ENV PATH="/opt/cargo/bin:/usr/lib/llvm-${LLVM_VERSION}/bin:${PATH}"

# Add builder user with sudo privilege
RUN useradd -m builder
RUN echo "builder ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers.d/builder

CMD su builder -c /usr/bin/env bash

FROM base as builder
COPY build-hyperfox.sh /home/builder/
RUN chmod +x /home/builder/build-hyperfox.sh
ENTRYPOINT ["/home/builder/build-hyperfox.sh"]

FROM base as package-deb
COPY build-deb.sh /home/builder/
COPY linux.hyperfox.desktop.in /home/builder/
RUN chmod +x /home/builder/build-deb.sh
ENTRYPOINT ["/home/builder/build-deb.sh"]

FROM archlinux:base-devel as package-arch

# Add packages
RUN pacman -Syu --noconfirm \
  git \
  gtk3 \
  libxt \
  startup-notification \
  mime-types \
  dbus \
  nss \
  ttf-font \
  libpulse \
  ffmpeg \
  zlib

# Add builder user with sudo privilege
RUN useradd -m builder
RUN echo "builder ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers.d/builder

COPY build-pkg.sh /home/builder
RUN chmod +x /home/builder/build-pkg.sh
CMD su builder -c /usr/bin/env bash
ENTRYPOINT ["/home/builder/build-pkg.sh"]
